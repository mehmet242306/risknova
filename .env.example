# =========================
# Frontend local file: frontend/.env.local
# =========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional frontend-only local key if Prisma/dev.db is needed
# DATABASE_URL=file:./dev.db

# Optional mail settings
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@example.com

# =========================
# Backend local file: backend/.env
# =========================
ENV=development
APP_NAME=RiskNova Backend
APP_VERSION=v1
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
JWT_SECRET=
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://guvenligimcepte.vercel.app
